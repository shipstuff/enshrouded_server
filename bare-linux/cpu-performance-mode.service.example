[Unit]
Description=Force CPU Performance Mode (bounded)
After=multi-user.target

[Service]
Type=oneshot
RemainAfterExit=yes
TimeoutStartSec=20
ExecStart=/usr/bin/bash -lc "[ -f /sys/devices/system/cpu/intel_pstate/min_perf_pct ] && echo 100 > /sys/devices/system/cpu/intel_pstate/min_perf_pct || true; [ -f /sys/devices/system/cpu/intel_pstate/max_perf_pct ] && echo 100 > /sys/devices/system/cpu/intel_pstate/max_perf_pct || true; timeout 10s cpupower frequency-set -g performance || true; timeout 10s x86_energy_perf_policy performance || true"

[Install]
WantedBy=multi-user.target
